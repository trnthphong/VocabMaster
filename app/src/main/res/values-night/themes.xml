<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for Dark Mode. -->
    <style name="Base.Theme.VocabMaster" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Brand Colors in Dark Mode -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorTertiary">@color/brand_accent</item>
        <item name="android:windowBackground">@color/surface_dark</item>
        <item name="android:statusBarColor">@color/surface_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Color mapping for components in Dark Mode -->
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">#1E293B</item>
        <item name="colorOnSurfaceVariant">@color/gray_light</item>

        <!-- Typography -->
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.VocabMaster.H1</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.VocabMaster.H2</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.VocabMaster.H3</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.VocabMaster.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.VocabMaster.BodyMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.VocabMaster.Caption</item>
    </style>

    <!-- Typography Styles Overrides for Dark Mode -->
    <style name="TextAppearance.VocabMaster.Display" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:textSize">@dimen/text_display</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.VocabMaster.H1" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">@dimen/text_h1</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.VocabMaster.H2" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">@dimen/text_h2</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.VocabMaster.H3" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">@dimen/text_h3</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.VocabMaster.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">@dimen/text_body_large</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.VocabMaster.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_body_medium</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.VocabMaster.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

</resources>
