<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.example.vocabmaster.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/navigation_library"
        android:name="com.example.vocabmaster.ui.library.LibraryFragment"
        android:label="Library"
        tools:layout="@layout/fragment_library" />

    <activity
        android:id="@+id/navigation_add_course"
        android:name="com.example.vocabmaster.ui.home.CreateCourseFlowActivity"
        android:label="Create Course" />

    <fragment
        android:id="@+id/navigation_social"
        android:name="com.example.vocabmaster.ui.social.SocialFragment"
        android:label="Social"
        tools:layout="@layout/fragment_social" />

    <fragment
        android:id="@+id/navigation_profile"
        android:name="com.example.vocabmaster.ui.profile.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_profile_to_settings"
            app:destination="@id/navigation_settings" />
        <action
            android:id="@+id/action_profile_to_premium"
            app:destination="@id/navigation_premium" />
    </fragment>

    <fragment
        android:id="@+id/navigation_settings"
        android:name="com.example.vocabmaster.ui.profile.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/navigation_premium"
        android:name="com.example.vocabmaster.ui.profile.PremiumFragment"
        android:label="Premium"
        tools:layout="@layout/fragment_premium">
        <action
            android:id="@+id/action_premium_to_success"
            app:destination="@id/navigation_premium_success" />
    </fragment>

    <fragment
        android:id="@+id/navigation_premium_success"
        android:name="com.example.vocabmaster.ui.profile.PremiumSuccessFragment"
        android:label="Premium Success"
        tools:layout="@layout/fragment_premium_success" >
        <argument
            android:name="plan_name"
            app:argType="string" />
        <argument
            android:name="days"
            app:argType="integer" />
    </fragment>

    <fragment
        android:id="@+id/navigation_manage_plans"
        android:name="com.example.vocabmaster.ui.profile.ManagePlansFragment"
        android:label="Manage Plans"
        tools:layout="@layout/fragment_manage_plans" />
</navigation>