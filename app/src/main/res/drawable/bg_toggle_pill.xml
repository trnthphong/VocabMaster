<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Trạng thái được chọn (Selected hoặc Checked) -->
    <item android:state_selected="true">
        <shape>
            <solid android:color="#F1F5F9" /> <!-- Giữ nguyên màu nền xám nhạt -->
            <corners android:radius="@dimen/radius_full" />
            <stroke
                android:width="2dp"
                android:color="@color/brand_primary" /> <!-- Chỉ đổi màu và độ dày viền -->
        </shape>
    </item>

    <item android:state_checked="true">
        <shape>
            <solid android:color="#F1F5F9" />
            <corners android:radius="@dimen/radius_full" />
            <stroke
                android:width="2dp"
                android:color="@color/brand_primary" />
        </shape>
    </item>

    <!-- Trạng thái mặc định -->
    <item>
        <shape>
            <solid android:color="#F1F5F9" />
            <corners android:radius="@dimen/radius_full" />
            <stroke
                android:width="1dp"
                android:color="#E2E8F0" />
        </shape>
    </item>
</selector>