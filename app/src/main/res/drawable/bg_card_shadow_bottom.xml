<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Shadow Layer 1 (More transparent, further out) -->
    <item
        android:bottom="0dp"
        android:left="2dp"
        android:right="2dp"
        android:top="6dp">
        <shape>
            <corners android:radius="@dimen/radius_large" />
            <solid android:color="#08000000" />
        </shape>
    </item>
    <!-- Inner Shadow Layer 2 (Slightly darker, closer in) -->
    <item
        android:bottom="2dp"
        android:left="1dp"
        android:right="1dp"
        android:top="4dp">
        <shape>
            <corners android:radius="@dimen/radius_large" />
            <solid android:color="#12000000" />
        </shape>
    </item>
    <!-- Main Background Layer -->
    <item
        android:bottom="4dp"
        android:left="0dp"
        android:right="0dp"
        android:top="0dp">
        <shape>
            <corners android:radius="@dimen/radius_large" />
            <solid android:color="@color/white" />
        </shape>
    </item>
</layer-list>
