<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Khi được chọn (Highlight) -->
    <item android:state_selected="true">
        <shape>
            <solid android:color="@color/brand_primary" /> <!-- Nền màu tím -->
            <corners android:radius="16dp" />
            <stroke
                android:width="2dp"
                android:color="@color/brand_primary" />
        </shape>
    </item>

    <!-- Trạng thái mặc định -->
    <item>
        <shape>
            <solid android:color="@color/white" /> <!-- Nền trắng -->
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="@color/card_border" />
        </shape>
    </item>
</selector>
