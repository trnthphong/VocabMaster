<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_light">

    <!-- Challenge Info -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_challenge_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeColor="@color/brand_primary_light"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/text_level_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Level 1: Đạt 50 ký tự"
                android:textColor="@color/brand_primary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/text_restriction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Không giới hạn"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <ProgressBar
                android:id="@+id/progress_goal"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="8dp"
                android:max="50"
                android:progress="0"
                android:progressTint="@color/brand_primary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Chat Area -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_chat"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/layout_input"
        android:layout_below="@id/card_challenge_info"
        android:clipToPadding="false"
        android:padding="16dp" />

    <!-- Timer Overlay -->
    <TextView
        android:id="@+id/text_word_timer"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_centerInParent="true"
        android:background="@drawable/bg_circle_glass"
        android:elevation="8dp"
        android:gravity="center"
        android:text="10"
        android:textColor="@color/brand_secondary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Input Area -->
    <LinearLayout
        android:id="@+id/layout_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/white"
        android:elevation="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <EditText
            android:id="@+id/edit_word_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_white_translucent_stroke"
            android:hint="Nhập từ vựng..."
            android:inputType="text"
            android:padding="12dp" />

            <ImageButton
            android:id="@+id/btn_send_word"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_circle_accent"
            android:src="@drawable/ic_arrow_forward"
            app:tint="@color/white" />
    </LinearLayout>

</RelativeLayout>
