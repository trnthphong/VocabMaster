<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#4046d8"
    android:clipChildren="false"
    android:clipToPadding="false">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            app:layout_scrollFlags="scroll|exitUntilCollapsed">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="120dp">

                <!-- Header Background with random icons -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:alpha="0.1"
                        android:rotation="-15"
                        android:src="@drawable/open_book"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.245"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_bias="0.2"
                        app:tint="@color/white" />

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:alpha="0.1"
                        android:rotation="-15"
                        android:src="@drawable/ranking"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.711"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_bias="0.7"
                        app:tint="@color/white" />

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:alpha="0.1"
                        android:rotation="20"
                        android:src="@drawable/puzzle"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.8"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_bias="0.15"
                        app:tint="@color/white" />

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:alpha="0.1"
                        android:rotation="10"
                        android:src="@drawable/speedup"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.096"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_bias="0.888"
                        app:tint="@color/white" />

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:alpha="0.1"
                        android:rotation="10"
                        android:src="@drawable/language"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.537"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_bias="0.0"
                        app:tint="@color/white" />

                    <ImageButton
                        android:id="@+id/btn_menu"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="16dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Menu"
                        android:padding="12dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/menus"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white" />

                    <!-- Top-Right Edit Profile Button -->
                    <ImageButton
                        android:id="@+id/btn_edit_profile"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginTop="16dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Edit Profile"
                        android:padding="12dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/draw"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_profile_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_32">

            <!-- Avatar centered on top edge of this white background -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_avatar"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="-60dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="60dp"
                app:cardElevation="12dp"
                app:strokeColor="@color/white"
                app:strokeWidth="4dp">

                <ImageView
                    android:id="@+id/image_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="User Avatar"
                    android:padding="20dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/bear" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Profile Info -->
            <TextView
                android:id="@+id/text_display_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/adlam_display"
                android:text="User Name"
                android:textAppearance="@style/TextAppearance.VocabMaster.H2"
                android:textColor="@color/text_primary" />

            <!-- ID Display with Copy Button -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/text_short_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ID: N/A"
                    android:textAppearance="@style/TextAppearance.VocabMaster.Caption"
                    android:textColor="@color/text_secondary" />

                <ImageButton
                    android:id="@+id/btn_copy_id"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Copy ID"
                    android:padding="4dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/copy"
                    app:tint="@color/text_secondary" />
            </LinearLayout>

            <!-- Header Stats Frame -->
            <LinearLayout
                android:id="@+id/stats_frame"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_glass_card"
                android:backgroundTint="#F1F5F9"
                android:elevation="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/image_course_flag"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Course Flag"
                        android:scaleType="centerInside"
                        android:src="@drawable/vietnam" />

                    <TextView
                        android:id="@+id/text_course_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Courses"
                        android:textAppearance="@style/TextAppearance.VocabMaster.Caption"
                        android:textColor="@color/text_primary" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="16dp"
                    android:layout_marginHorizontal="12dp"
                    android:background="#E2E8F0" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Friends Icon"
                        android:src="@drawable/happy" />

                    <TextView
                        android:id="@+id/text_friends_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="0 Bạn bè"
                        android:textAppearance="@style/TextAppearance.VocabMaster.Caption"
                        android:textColor="@color/text_primary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_friend_action"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_login_neumorph"
                    android:text="Thêm bạn bè"
                    android:textColor="@color/bg_grey"
                    app:backgroundTint="@null"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/add_user"
                    app:iconTint="@color/bg_grey" />

                <FrameLayout
                    android:id="@+id/btn_qr_code"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/button_login_neumorph"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="QR Code"
                        android:padding="14dp"
                        android:src="@drawable/qr_code"
                        app:tint="@color/bg_grey" />
                </FrameLayout>
            </LinearLayout>

            <!-- Tab Selector -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_layout_profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@android:color/transparent"
                app:tabIndicatorColor="@color/brand_primary"
                app:tabSelectedTextColor="@color/brand_primary"
                app:tabTextColor="@color/text_secondary"
                app:tabIndicatorFullWidth="false"
                app:tabIndicatorHeight="3dp"
                app:tabRippleColor="@android:color/transparent">

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tiến trình" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bản tin" />
            </com.google.android.material.tabs.TabLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- My Process Section -->
                <LinearLayout
                    android:id="@+id/layout_my_process"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/spacing_16"
                    android:visibility="visible">

                    <!-- Learning Stats Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_learning_stats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_16"
                        app:cardBackgroundColor="@color/white"
                        app:strokeWidth="0dp"
                        app:cardElevation="2dp"
                        app:cardCornerRadius="24dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_20">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">
                                <TextView
                                    android:id="@+id/text_stats_course_title"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Tiến độ học tập"
                                    android:textAppearance="@style/TextAppearance.VocabMaster.H3"
                                    android:textColor="@color/brand_primary" />

                                <ImageView
                                    android:id="@+id/image_stat_course"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/eng"
                                    android:contentDescription="Course Icon" />
                            </LinearLayout>

                            <GridLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_16"
                                android:columnCount="2"
                                android:alignmentMode="alignMargins"
                                android:useDefaultMargins="true">

                                <!-- XP -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:paddingVertical="8dp">
                                    <ImageView
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        android:src="@drawable/exp"
                                        android:contentDescription="XP Icon" />
                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="12dp"
                                        android:orientation="vertical">
                                        <TextView
                                            android:id="@+id/text_xp_value"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="0"
                                            android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                                            android:textStyle="bold" />
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="Tổng XP"
                                            android:textSize="12sp"
                                            android:textColor="@color/gray_text" />
                                    </LinearLayout>
                                </LinearLayout>

                                <!-- Streak -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:paddingVertical="8dp">
                                    <ImageView
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        android:src="@drawable/streak"
                                        android:contentDescription="Streak Icon" />
                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="12dp"
                                        android:orientation="vertical">
                                        <TextView
                                            android:id="@+id/text_streak_value"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="0"
                                            android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                                            android:textStyle="bold" />
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="Ngày học"
                                            android:textSize="12sp"
                                            android:textColor="@color/gray_text" />
                                    </LinearLayout>
                                </LinearLayout>

                                <!-- Hearts -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_columnWeight="1"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:paddingVertical="8dp">
                                    <ImageView
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        android:src="@drawable/heart"
                                        android:contentDescription="Hearts Icon" />
                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="12dp"
                                        android:orientation="vertical">
                                        <TextView
                                            android:id="@+id/text_hearts_value"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="5"
                                            android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                                            android:textStyle="bold" />
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="Sinh lực"
                                            android:textSize="12sp"
                                            android:textColor="@color/gray_text" />
                                    </LinearLayout>
                                </LinearLayout>

                            </GridLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Feed Section -->
                <LinearLayout
                    android:id="@+id/layout_feed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/spacing_16"
                    android:visibility="gone">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_16"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="2dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="32dp">

                            <ImageView
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:alpha="0.5"
                                android:src="@drawable/puzzle"
                                app:tint="@color/brand_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:text="Chưa có bài đăng nào"
                                android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                                android:textColor="@color/text_secondary" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_create_post"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Chia sẻ bài học đầu tiên"
                                android:textColor="@color/brand_primary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
