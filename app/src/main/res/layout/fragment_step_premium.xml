<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="@dimen/spacing_24">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="@dimen/spacing_32"
        android:src="@drawable/vocab" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_24"
        android:text="Mở khóa tiềm năng"
        android:textAppearance="@style/TextAppearance.VocabMaster.H1"
        android:textAlignment="center" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_12"
        android:text="Nâng cấp Premium để học không giới hạn, không quảng cáo và mở khóa tất cả mini-games."
        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
        android:textAlignment="center" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_32"
        app:cardBackgroundColor="@color/brand_primary"
        app:cardCornerRadius="@dimen/radius_large"
        app:contentPadding="@dimen/spacing_24">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chỉ 49.000đ / tháng"
                android:textAppearance="@style/TextAppearance.VocabMaster.H2"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_4"
                android:text="Học tập chuyên nghiệp hơn ngay hôm nay"
                android:textAppearance="@style/TextAppearance.VocabMaster.BodySmall"
                android:textColor="@color/white" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/btn_skip_premium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_24"
        android:padding="@dimen/spacing_12"
        android:text="Để sau"
        android:textAppearance="@style/TextAppearance.VocabMaster.BodyMedium"
        android:textColor="@color/gray_text" />

</LinearLayout>