<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.auth.ForgotPasswordActivity">

    <!-- Background Decorative Icons -->
    <ImageView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/star"
        android:alpha="0.15"
        android:rotation="-15"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="40dp"
        android:layout_marginStart="40dp" />

    <ImageView
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/heart"
        android:alpha="0.12"
        android:rotation="20"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="60dp" />

    <ImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/brain"
        android:alpha="0.1"
        android:rotation="-10"
        app:layout_constraintTop_toBottomOf="@id/card_logo"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="-20dp"
        android:layout_marginStart="30dp" />

    <ImageView
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/diamond"
        android:alpha="0.12"
        android:rotation="15"
        app:layout_constraintTop_toBottomOf="@id/card_logo"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="40dp" />

    <!-- Logo Section -->
    <soup.neumorphism.NeumorphCardView
        android:id="@+id/card_logo"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:neumorph_shapeType="flat"
        app:neumorph_backgroundColor="@color/white"
        app:neumorph_shadowColorDark="#D1D9E6"
        app:neumorph_shadowColorLight="#FFFFFF"
        app:neumorph_shadowElevation="6dp"
        app:neumorph_strokeColor="#F0F0F0"
        app:neumorph_strokeWidth="1dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp"
            android:src="@drawable/vocab2"
            android:scaleType="centerInside" />
    </soup.neumorphism.NeumorphCardView>

    <!-- Custom Wave Card View -->
    <com.example.vocabmaster.ui.common.WaveCardView
        android:id="@+id/card_forgot"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="-40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_logo">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="32dp"
                android:paddingTop="100dp"
                android:paddingBottom="40dp">

                <TextView
                    android:id="@+id/title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RESET PASSWORD"
                    android:textColor="@color/white"
                    android:textSize="32sp"
                    android:fontFamily="@font/adlam_display"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Enter your email to reset password"
                    android:textColor="#B0B4FF"
                    android:textSize="16sp" />

                <!-- Neumorphic Input: Email -->
                <soup.neumorphism.NeumorphCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    app:neumorph_backgroundColor="#4046d8"
                    app:neumorph_shadowColorDark="#2D32A0"
                    app:neumorph_shadowColorLight="#555BFF"
                    app:neumorph_shapeType="pressed">

                    <EditText
                        android:id="@+id/edit_email"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@android:color/transparent"
                        android:hint="Email address"
                        android:inputType="textEmailAddress"
                        android:paddingHorizontal="20dp"
                        android:drawableStart="@drawable/ic_email"
                        android:drawablePadding="12dp"
                        android:drawableTint="#B0B4FF"
                        android:textColor="@color/white"
                        android:textColorHint="#8E94FF"
                        android:textSize="16sp" />
                </soup.neumorphism.NeumorphCardView>

                <!-- Reset Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_send_reset_link"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/button_login_neumorph"
                    app:backgroundTint="@null"
                    android:text="SEND RESET LINK"
                    android:textColor="@color/bg_grey"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp"
                    app:elevation="0dp" />

                <!-- Back to Login Link -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_back_login"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Back to sign in"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:textAllCaps="false" />

            </LinearLayout>
        </ScrollView>
    </com.example.vocabmaster.ui.common.WaveCardView>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:elevation="10dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
