<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_light">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#4046D8"
        app:navigationIcon="@drawable/left_arrow"
        app:navigationIconTint="@color/white"
        app:titleTextColor="@color/white" />

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <TextView
        android:id="@+id/text_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="32dp"
        android:text="Chưa có từ vựng nào.\nNhấn nút bên dưới để thêm từ mới."
        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_vocab"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:background="#4046D8"
        android:padding="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#4046D8"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_word"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:text="Thêm từ mới"
            android:textSize="16sp"
            android:textColor="@color/white"
            app:cornerRadius="12dp"
            app:strokeColor="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Xong"
            android:background="@drawable/button_login_neumorph"
            android:textColor="@color/bg_grey"
            app:backgroundTint="@null"
            android:textSize="16sp"
            app:cornerRadius="12dp" />
    </LinearLayout>

</LinearLayout>
