<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingHorizontal="8dp"
    android:paddingVertical="16dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_flashcard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Front Side -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/card_front"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp">

                <TextView
                    android:id="@+id/label_topic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_card"
                    android:backgroundTint="@color/brand_secondary"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="TOPIC"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/image_vocab"
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_marginTop="12dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/label_topic"
                    tools:src="@android:drawable/ic_menu_gallery"
                    tools:visibility="visible" />
                <TextView
                    android:id="@+id/text_word"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textAlignment="center"
                    android:textAppearance="@style/TextAppearance.VocabMaster.H2"
                    android:textColor="@color/brand_primary"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/image_vocab"
                    tools:text="Vocabulary" />

                <TextView
                    android:id="@+id/text_phonetic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="/phonetic/"
                    android:textAppearance="@style/TextAppearance.VocabMaster.Caption"
                    android:textColor="@color/text_secondary"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_word"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/text_vietnamese"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Nghĩa tiếng Việt"
                    android:textAppearance="@style/TextAppearance.VocabMaster.Caption"
                    android:textColor="@color/brand_primary"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_phonetic"
                    tools:text="🇻🇳 Nghĩa tiếng Việt"
                    tools:visibility="visible" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textSize="10sp"
                    android:visibility="gone"
                    app:chipMinHeight="24dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_vietnamese"
                    tools:text="Đang học"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/text_tap_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap để xem nghĩa"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toTopOf="@id/btn_learn_this"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_learn_this"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:text="Học từ này"
                    android:textAllCaps="false"
                    app:cornerRadius="12dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Back Side -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/card_back"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/label_topic_back"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_card"
                    android:backgroundTint="@color/brand_secondary"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="Nghĩa"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/text_definition"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:paddingHorizontal="8dp"
                    android:textAlignment="center"
                    android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/label_topic_back"
                    tools:text="Definition goes here" />

                <TextView
                    android:id="@+id/text_example"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:paddingHorizontal="8dp"
                    android:textAlignment="center"
                    android:textAppearance="@style/TextAppearance.VocabMaster.Caption"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="italic"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_definition"
                    tools:text="Example sentence using this vocabulary word." />

                <TextView
                    android:id="@+id/text_tap_hint_back"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap để quay lại"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toTopOf="@id/btn_learn_this_back"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_learn_this_back"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:text="Học từ này"
                    android:textAllCaps="false"
                    app:cornerRadius="12dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
