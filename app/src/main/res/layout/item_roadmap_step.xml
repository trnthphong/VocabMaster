<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="16dp">

    <View
        android:id="@+id/view_line"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="@color/gray_light"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/image_step_icon"
        app:layout_constraintStart_toStartOf="@id/image_step_icon"
        app:layout_constraintTop_toBottomOf="@id/image_step_icon" />

    <ImageView
        android:id="@+id/image_step_icon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_circle_accent"
        android:padding="12dp"
        android:src="@drawable/ic_listen"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/image_step_icon"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/text_step_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Level 1"
                android:textAppearance="@style/TextAppearance.VocabMaster.Caption"
                android:textColor="@color/brand_primary" />

            <TextView
                android:id="@+id/text_step_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kỹ năng Nghe"
                android:textAppearance="@style/TextAppearance.VocabMaster.H3" />

            <TextView
                android:id="@+id/text_step_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Luyện tập nhận diện âm thanh và từ vựng cơ bản."
                android:textAppearance="@style/TextAppearance.VocabMaster.BodySmall" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
