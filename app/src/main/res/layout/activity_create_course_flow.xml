<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#4046d8"
    tools:context=".ui.course.CreateCourseFlowActivity">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_flow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_16"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back_flow"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <!-- Dot Progress Indicator Container -->
        <LinearLayout
            android:id="@+id/layout_dots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_back_flow"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/dot_1"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginHorizontal="6dp"
                android:src="@drawable/ic_dot_active" />

            <ImageView
                android:id="@+id/dot_2"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginHorizontal="6dp"
                android:src="@drawable/ic_dot_inactive" />

            <ImageView
                android:id="@+id/dot_3"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginHorizontal="6dp"
                android:src="@drawable/ic_dot_inactive" />

            <ImageView
                android:id="@+id/dot_4"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginHorizontal="6dp"
                android:src="@drawable/ic_dot_inactive" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation_flow"
        app:layout_constraintTop_toBottomOf="@id/header_flow">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/spacing_24">

            <!-- Step 1: Language -->
            <LinearLayout
                android:id="@+id/layout_step_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bạn muốn học ngôn ngữ nào?"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:fontFamily="@font/adlam_display"
                    android:textStyle="bold"
                    android:layout_marginBottom="@dimen/spacing_24"/>

                <RadioGroup
                    android:id="@+id/radio_group_language"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/radio_en"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_selectable_item_3d"
                        android:button="@null"
                        android:drawableStart="@drawable/eng"
                        android:drawablePadding="16dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="Tiếng Anh"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                        android:textColor="#4046d8"
                        android:textStyle="bold" />

                    <RadioButton
                        android:id="@+id/radio_ja"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_selectable_item_3d"
                        android:button="@null"
                        android:drawableStart="@drawable/japan"
                        android:drawablePadding="16dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="Tiếng Nhật"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                        android:textColor="#4046d8"
                        android:textStyle="bold" />

                    <RadioButton
                        android:id="@+id/radio_rus"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_selectable_item_3d"
                        android:button="@null"
                        android:drawableStart="@drawable/russia"
                        android:drawablePadding="16dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="Tiếng Nga"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                        android:textColor="#4046d8"
                        android:textStyle="bold" />

                    <RadioButton
                        android:id="@+id/radio_zh"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_selectable_item_3d"
                        android:button="@null"
                        android:drawableStart="@drawable/china"
                        android:drawablePadding="16dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="Tiếng Trung"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                        android:textColor="#4046d8"
                        android:textStyle="bold" />
                </RadioGroup>
            </LinearLayout>

            <!-- Step 2: Proficiency Level -->
            <LinearLayout
                android:id="@+id/layout_step_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trình độ của bạn?"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:fontFamily="@font/adlam_display"
                    android:textStyle="bold"
                    android:layout_marginBottom="@dimen/spacing_24"/>

                <RadioGroup
                    android:id="@+id/radio_group_level"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/level_beginner"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_selectable_item_3d"
                        android:button="@null"
                        android:paddingStart="20dp"
                        android:text="Mới bắt đầu (Beginner)"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                        android:textColor="#4046d8"
                        android:textStyle="bold" />

                    <RadioButton
                        android:id="@+id/level_elementary"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_selectable_item_3d"
                        android:button="@null"
                        android:paddingStart="20dp"
                        android:text="Cơ bản (Elementary)"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                        android:textColor="#4046d8"
                        android:textStyle="bold" />

                    <RadioButton
                        android:id="@+id/level_intermediate"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_selectable_item_3d"
                        android:button="@null"
                        android:paddingStart="20dp"
                        android:text="Trung cấp (Intermediate)"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                        android:textColor="#4046d8"
                        android:textStyle="bold" />

                    <RadioButton
                        android:id="@+id/level_advanced"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_selectable_item_3d"
                        android:button="@null"
                        android:paddingStart="20dp"
                        android:text="Nâng cao (Advanced)"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                        android:textColor="#4046d8"
                        android:textStyle="bold" />
                </RadioGroup>
            </LinearLayout>

            <!-- Step 3: Favorite Topics -->
            <LinearLayout
                android:id="@+id/layout_step_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chọn các chủ đề yêu thích"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:fontFamily="@font/adlam_display"
                    android:textStyle="bold"
                    android:layout_marginBottom="@dimen/spacing_8"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bạn có thể chọn nhiều chủ đề"
                    android:textColor="#B0B4FF"
                    android:textSize="16sp"
                    android:layout_marginBottom="@dimen/spacing_24"/>

                <LinearLayout
                    android:id="@+id/list_topics"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <CheckBox
                        android:id="@+id/cb_career"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_selectable_item_3d"
                        android:button="@null"
                        android:drawableStart="@drawable/career"
                        android:drawablePadding="16dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="Nghề nghiệp"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                        android:textColor="#4046d8"
                        android:textStyle="bold" />

                    <CheckBox
                        android:id="@+id/cb_school"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_selectable_item_3d"
                        android:button="@null"
                        android:drawableStart="@drawable/school"
                        android:drawablePadding="16dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="Trường học"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                        android:textColor="#4046d8"
                        android:textStyle="bold" />

                    <CheckBox
                        android:id="@+id/cb_culture"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_selectable_item_3d"
                        android:button="@null"
                        android:drawableStart="@drawable/culture"
                        android:drawablePadding="16dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="Văn hóa"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                        android:textColor="#4046d8"
                        android:textStyle="bold" />

                    <CheckBox
                        android:id="@+id/cb_travel"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_selectable_item_3d"
                        android:button="@null"
                        android:drawableStart="@drawable/travel"
                        android:drawablePadding="16dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="Du lịch"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                        android:textColor="#4046d8"
                        android:textStyle="bold" />

                    <CheckBox
                        android:id="@+id/cb_food"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_selectable_item_3d"
                        android:button="@null"
                        android:drawableStart="@drawable/food"
                        android:drawablePadding="16dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="Thức ăn"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                        android:textColor="#4046d8"
                        android:textStyle="bold" />

                    <CheckBox
                        android:id="@+id/cb_tech"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_selectable_item_3d"
                        android:button="@null"
                        android:drawableStart="@drawable/brainskill"
                        android:drawablePadding="16dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="Công nghệ"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                        android:textColor="#4046d8"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Step 4: Time -->
            <LinearLayout
                android:id="@+id/layout_step_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mục tiêu hàng ngày?"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:fontFamily="@font/adlam_display"
                    android:textStyle="bold"
                    android:layout_marginBottom="@dimen/spacing_24"/>

                <RadioGroup
                    android:id="@+id/radio_group_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <RadioButton android:id="@+id/radio_5min" android:layout_width="match_parent" android:layout_height="64dp" android:text="5 phút / ngày" android:paddingStart="20dp" android:layout_marginBottom="12dp" android:background="@drawable/bg_selectable_item_3d" android:button="@null" android:textColor="#4046d8" android:textStyle="bold" />
                    <RadioButton android:id="@+id/radio_10min" android:layout_width="match_parent" android:layout_height="64dp" android:text="10 phút / ngày" android:checked="true" android:paddingStart="20dp" android:layout_marginBottom="12dp" android:background="@drawable/bg_selectable_item_3d" android:button="@null" android:textColor="#4046d8" android:textStyle="bold" />
                    <RadioButton android:id="@+id/radio_15min" android:layout_width="match_parent" android:layout_height="64dp" android:text="15 phút / ngày" android:paddingStart="20dp" android:layout_marginBottom="12dp" android:background="@drawable/bg_selectable_item_3d" android:button="@null" android:textColor="#4046d8" android:textStyle="bold" />
                </RadioGroup>
            </LinearLayout>

        </FrameLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_navigation_flow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_24"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next_flow"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="Tiếp tục"
            android:textColor="@color/bg_grey"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/button_login_neumorph"
            app:backgroundTint="@null"
            app:cornerRadius="16dp"
            app:elevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
