<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_24">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chủ đề quan tâm"
            android:textAppearance="@style/TextAppearance.VocabMaster.H1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_8"
            android:text="Chúng tôi sẽ cá nhân hóa từ vựng cho bạn"
            android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge" />

        <LinearLayout
            android:id="@+id/layout_themes_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_32"
            android:orientation="vertical">

            <!-- Tái sử dụng các hàng LinearLayout từ dialog_add_course_modern.xml -->
            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/chip_career"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing_4"
                    android:layout_marginBottom="@dimen/spacing_8"
                    android:layout_weight="1"
                    android:background="@drawable/bg_toggle_pill"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_12">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/career" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_8"
                        android:text="Nghề nghiệp"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyMedium"
                        android:textColor="@color/surface_dark" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/chip_school"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_4"
                    android:layout_marginBottom="@dimen/spacing_8"
                    android:layout_weight="1"
                    android:background="@drawable/bg_toggle_pill"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_12">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/school" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_8"
                        android:text="Trường học"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyMedium"
                        android:textColor="@color/surface_dark" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/chip_culture"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing_4"
                    android:layout_marginBottom="@dimen/spacing_8"
                    android:layout_weight="1"
                    android:background="@drawable/bg_toggle_pill"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_12">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/culture" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_8"
                        android:text="Văn hóa"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyMedium"
                        android:textColor="@color/surface_dark" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/chip_travel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_4"
                    android:layout_marginBottom="@dimen/spacing_8"
                    android:layout_weight="1"
                    android:background="@drawable/bg_toggle_pill"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_12">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/travel" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_8"
                        android:text="Du lịch"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyMedium"
                        android:textColor="@color/surface_dark" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 3: Food & Brain -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/chip_food"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing_4"
                    android:layout_marginBottom="@dimen/spacing_8"
                    android:layout_weight="1"
                    android:background="@drawable/bg_toggle_pill"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_12">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/food" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_8"
                        android:text="Thức ăn"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyMedium"
                        android:textColor="@color/surface_dark" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/chip_brain"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_4"
                    android:layout_marginBottom="@dimen/spacing_8"
                    android:layout_weight="1"
                    android:background="@drawable/bg_toggle_pill"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_12">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/brain" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_8"
                        android:text="Luyện trí não"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyMedium"
                        android:textColor="@color/surface_dark" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>