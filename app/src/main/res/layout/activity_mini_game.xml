<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_blue">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bar_height"
        android:paddingHorizontal="@dimen/spacing_16"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/close"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/blue" />

        <TextView
            android:id="@+id/text_mini_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Score: 0"
            android:textColor="@color/blue"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/game_progress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            app:indicatorColor="@color/brand_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/text_mini_score"
            app:layout_constraintStart_toEndOf="@id/btn_close"
            app:layout_constraintTop_toTopOf="parent"
            app:trackColor="@color/white"
            app:trackCornerRadius="10dp"
            app:trackThickness="8dp"
            android:progress="0" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Content Area -->
    <FrameLayout
        android:id="@+id/game_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="24dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar"
        app:layout_constraintTop_toBottomOf="@id/header">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="24dp">

                <!-- 1. Listening MCQ -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_listen_mcq"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone">
                    <TextView
                        android:id="@+id/title_listen_mcq"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nghe và chọn từ đúng"
                        android:textAlignment="center"
                        android:textStyle="bold"
                        app:layout_constraintTop_toTopOf="parent" />
                    <ImageButton
                        android:id="@+id/btn_play_audio_mcq"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:background="@drawable/bg_circle_accent"
                        android:src="@drawable/volume"
                        app:layout_constraintBottom_toTopOf="@id/layout_options_mcq"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/title_listen_mcq"
                        app:tint="@color/white" />
                    <LinearLayout
                        android:id="@+id/layout_options_mcq"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent">
                        <Button android:id="@+id/btn_opt1" android:layout_width="match_parent" android:layout_height="60dp" android:layout_marginBottom="8dp" android:background="@drawable/bg_selectable_option" app:backgroundTint="@null" android:textColor="@color/brand_primary" />
                        <Button android:id="@+id/btn_opt2" android:layout_width="match_parent" android:layout_height="60dp" android:layout_marginBottom="8dp" android:background="@drawable/bg_selectable_option" app:backgroundTint="@null" android:textColor="@color/brand_primary" />
                        <Button android:id="@+id/btn_opt3" android:layout_width="match_parent" android:layout_height="60dp" android:background="@drawable/bg_selectable_option" app:backgroundTint="@null" android:textColor="@color/brand_primary" />
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- 2. Listening Writing -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_listen_write"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nghe và gõ lại từ"
                        android:textAlignment="center"
                        android:textStyle="bold"
                        app:layout_constraintTop_toTopOf="parent" />
                    <ImageButton
                        android:id="@+id/btn_play_audio_write"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:background="@drawable/bg_circle_accent"
                        android:src="@drawable/volume"
                        app:layout_constraintBottom_toTopOf="@id/edit_answer_write"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white" />
                    <EditText
                        android:id="@+id/edit_answer_write"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:hint="Gõ từ bạn nghe được..."
                        android:textAlignment="center"
                        app:layout_constraintBottom_toBottomOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- 3. Meaning MCQ -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_meaning_mcq"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone">
                    <TextView
                        android:id="@+id/text_target_word"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Word"
                        android:textAppearance="@style/TextAppearance.VocabMaster.Display"
                        android:textAlignment="center"
                        app:layout_constraintTop_toTopOf="parent" />
                    <LinearLayout
                        android:id="@+id/layout_meaning_options"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent">
                        <Button android:id="@+id/btn_m_opt1" android:layout_width="match_parent" android:layout_height="60dp" android:layout_marginBottom="8dp" android:background="@drawable/bg_selectable_option" app:backgroundTint="@null" android:textColor="@color/brand_primary" />
                        <Button android:id="@+id/btn_m_opt2" android:layout_width="match_parent" android:layout_height="60dp" android:layout_marginBottom="8dp" android:background="@drawable/bg_selectable_option" app:backgroundTint="@null" android:textColor="@color/brand_primary" />
                        <Button android:id="@+id/btn_m_opt3" android:layout_width="match_parent" android:layout_height="60dp" android:background="@drawable/bg_selectable_option" app:backgroundTint="@null" android:textColor="@color/brand_primary" />
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- 4. Meaning Writing -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_meaning_write"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone">
                    <TextView
                        android:id="@+id/text_target_definition"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Định nghĩa của từ."
                        android:textAppearance="@style/TextAppearance.VocabMaster.H2"
                        android:textAlignment="center"
                        app:layout_constraintBottom_toTopOf="@id/edit_word_write"
                        app:layout_constraintTop_toTopOf="parent" />
                    <EditText
                        android:id="@+id/edit_word_write"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:hint="Từ này là gì?"
                        android:textAlignment="center"
                        app:layout_constraintBottom_toBottomOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

    <!-- Bottom Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintBottom_toBottomOf="parent">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_check_answer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="KIỂM TRA"
            app:cornerRadius="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
