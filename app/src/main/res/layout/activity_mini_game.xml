<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_tab_match"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Match" />

        <Button
            android:id="@+id/btn_tab_mcq"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="MCQ" />

        <Button
            android:id="@+id/btn_tab_speed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Speed" />
    </LinearLayout>

    <TextView
        android:id="@+id/text_mini_score"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Score: 0"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/layout_match"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="vertical">

        <TextView android:id="@+id/match_word_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="abundant" />
        <TextView android:id="@+id/match_def_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="lasting a short time" />
        <CheckBox android:id="@+id/chk_11" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pair word 1 with def 1" />
        <TextView android:id="@+id/match_word_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="brief" />
        <TextView android:id="@+id/match_def_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="existing in large quantities" />
        <CheckBox android:id="@+id/chk_22" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pair word 2 with def 2" />

        <Button
            android:id="@+id/btn_check_match"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Check answers" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_mcq"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="vertical"
        android:visibility="gone">
        <TextView android:id="@+id/text_mcq_question" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Question" />
        <Button android:id="@+id/btn_mcq_a" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="A" />
        <Button android:id="@+id/btn_mcq_b" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="B" />
        <Button android:id="@+id/btn_mcq_c" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="C" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_speed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="vertical"
        android:visibility="gone">
        <TextView android:id="@+id/text_speed_timer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Time left: 10s" />
        <TextView android:id="@+id/text_speed_prompt" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Type the matching word..." />
        <EditText android:id="@+id/edit_speed_answer" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Your answer" />
        <Button android:id="@+id/btn_start_speed" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Start round" />
        <Button android:id="@+id/btn_speed_submit" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Submit answer" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_close"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Back" />

</LinearLayout>
