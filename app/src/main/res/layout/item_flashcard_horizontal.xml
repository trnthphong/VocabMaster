<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_flashcard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Front Side -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/card_front"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="24dp">

                <!-- Delete Button -->
                <ImageButton
                    android:id="@+id/btn_delete"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_menu_delete"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/brand_primary" />

                <TextView
                    android:id="@+id/label_topic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_card"
                    android:backgroundTint="@color/brand_secondary"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="TOPIC"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/image_vocab"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_marginTop="16dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/label_topic"
                    tools:src="@android:drawable/ic_menu_gallery"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/text_word"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:textAppearance="@style/TextAppearance.VocabMaster.H1"
                    android:textColor="@color/brand_primary"
                    android:textSize="42sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toTopOf="@id/text_phonetic"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/image_vocab"
                    app:layout_constraintVertical_chainStyle="packed"
                    tools:text="Vocabulary" />

                <TextView
                    android:id="@+id/text_phonetic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="/phonetic/"
                    android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                    android:textColor="@color/text_secondary"
                    android:visibility="gone"
                    app:layout_constraintBottom_toTopOf="@id/text_vietnamese"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_word"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/text_vietnamese"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textSize="16sp"
                    android:textColor="@color/brand_secondary"
                    android:textStyle="italic"
                    android:visibility="gone"
                    app:layout_constraintBottom_toTopOf="@id/text_tap_hint"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_phonetic"
                    tools:text="xin chào"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/text_tap_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Tap to flip"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Back Side -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/card_back"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="24dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/text_definition"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:textAppearance="@style/TextAppearance.VocabMaster.H3"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    app:layout_constraintBottom_toTopOf="@id/text_example"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_chainStyle="packed"
                    tools:text="Definition goes here" />

                <TextView
                    android:id="@+id/text_example"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:textAlignment="center"
                    android:textAppearance="@style/TextAppearance.VocabMaster.BodyMedium"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:textStyle="italic"
                    app:layout_constraintBottom_toTopOf="@id/text_tap_hint_back"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_definition"
                    tools:text="Example sentence using this vocabulary word." />

                <TextView
                    android:id="@+id/text_tap_hint_back"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Tap to flip back"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
