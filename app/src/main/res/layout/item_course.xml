<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_8"
    android:layout_marginVertical="@dimen/spacing_8"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="@dimen/radius_large"
    app:cardElevation="@dimen/elevation_low"
    app:strokeColor="@color/card_border"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_16">

        <View
            android:id="@+id/view_indicator"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_glass_card"
            android:backgroundTint="@color/brand_primary"
            app:layout_constraintBottom_toBottomOf="@id/text_course_description"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/text_course_title" />

        <TextView
            android:id="@+id/text_course_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_12"
            android:text="IELTS Vocabulary"
            android:textAppearance="@style/TextAppearance.VocabMaster.H3"
            app:layout_constraintEnd_toStartOf="@id/icon_more"
            app:layout_constraintStart_toEndOf="@id/view_indicator"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/text_course_description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_12"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Comprehensive set for IELTS academic preparation."
            android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/view_indicator"
            app:layout_constraintTop_toBottomOf="@id/text_course_title" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12"
            android:background="@drawable/bg_glass_card"
            android:backgroundTint="@color/surface_light"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            app:layout_constraintStart_toStartOf="@id/text_course_description"
            app:layout_constraintTop_toBottomOf="@id/text_course_description">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@android:drawable/ic_menu_today"
                app:tint="@color/brand_primary" />

            <TextView
                android:id="@+id/text_flashcard_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="120 cards"
                android:textColor="@color/brand_primary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageView
            android:id="@+id/icon_more"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_more"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/gray_light" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>