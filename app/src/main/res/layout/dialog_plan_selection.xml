<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#4046d8">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:background="#E0E0E0"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/text_dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chọn thời hạn đăng ký"
        app:fontFamily="@font/adlam_display"
        android:textColor="@color/white"
        android:textAppearance="@style/TextAppearance.VocabMaster.H3"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/text_dialog_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gói VIP"
        android:textAppearance="@style/TextAppearance.VocabMaster.BodyMedium"
        android:textColor="@color/white"
        android:layout_marginBottom="24dp"/>

    <RadioGroup
        android:id="@+id/radio_group_duration"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/radio_7_days"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="7 ngày"
            android:textColor="@color/white"
            android:buttonTint="@color/white"
            android:background="@drawable/bg_radio_plan"
            android:layout_marginBottom="8dp"
            android:paddingStart="12dp"
            app:buttonTint="@color/white"
            app:useMaterialThemeColors="false"/>

        <RadioButton
            android:id="@+id/radio_30_days"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:textColor="@color/white"
            android:text="30 ngày (Phổ biến)"
            android:checked="true"
            android:buttonTint="@color/white"
            android:background="@drawable/bg_radio_plan"
            android:layout_marginBottom="8dp"
            android:paddingStart="12dp"
            app:buttonTint="@color/white"
            app:useMaterialThemeColors="false"/>

        <RadioButton
            android:id="@+id/radio_90_days"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="90 ngày"
            android:textColor="@color/white"
            android:buttonTint="@color/white"
            android:background="@drawable/bg_radio_plan"
            android:layout_marginBottom="8dp"
            android:paddingStart="12dp"
            app:buttonTint="@color/white"
            app:useMaterialThemeColors="false"/>

        <RadioButton
            android:id="@+id/radio_180_days"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="180 ngày"
            android:textColor="@color/white"
            android:buttonTint="@color/white"
            android:background="@drawable/bg_radio_plan"
            android:layout_marginBottom="8dp"
            android:paddingStart="12dp"
            app:buttonTint="@color/white"
            app:useMaterialThemeColors="false"/>

        <RadioButton
            android:id="@+id/radio_360_days"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:textColor="@color/white"
            android:text="360 ngày (Tiết kiệm nhất)"
            android:buttonTint="@color/white"
            android:background="@drawable/bg_radio_plan"
            android:layout_marginBottom="8dp"
            android:paddingStart="12dp"
            app:buttonTint="@color/white"
            app:useMaterialThemeColors="false"/>
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Phương thức thanh toán"
        android:textColor="@color/white"
        android:textAppearance="@style/TextAppearance.VocabMaster.LabelMedium"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="12dp"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/white"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardElevation="0dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/momo" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="Ví MoMo"
                android:textColor="@color/white"
                android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                android:textStyle="bold" />
            <RadioButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:buttonTint="@color/white"
                app:buttonTint="@color/white"
                app:useMaterialThemeColors="false"
                android:clickable="false"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Total Amount Display -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/white"
            android:text="Tổng tiền thanh toán:"
            android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge" />
        <TextView
            android:id="@+id/text_total_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 ₫"
            android:textColor="@color/white"
            android:textAppearance="@style/TextAppearance.VocabMaster.H3" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_confirm_payment"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:text="Thanh toán ngay"
        android:textColor="@color/bg_grey"
        android:backgroundTint="@color/light_green"
        android:textAppearance="@style/TextAppearance.VocabMaster.H3"
        app:cornerRadius="16dp"/>

</LinearLayout>
