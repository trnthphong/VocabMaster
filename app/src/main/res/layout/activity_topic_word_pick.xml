<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#4046D8">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/left_arrow"
        app:navigationIconTint="@color/white"

        android:textColor="@color/white"
        />

    <!-- Header info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/text_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chọn từ bạn muốn học"
            android:textColor="@color/white"
            android:textAppearance="@style/TextAppearance.VocabMaster.Caption" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_select_all"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="Chọn tất cả"
                android:textColor="@color/white"
                android:strokeColor="@color/white"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_shuffle"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔀 Xáo trộn"
                android:textColor="@color/white"/>
        </LinearLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <TextView
        android:id="@+id/text_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="32dp"
        android:text="Bạn đã học hết tất cả từ trong bộ này! 🎉"
        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
        android:visibility="gone" />

    <TextView
        android:id="@+id/text_card_counter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="4dp"
        android:text="1 / 10"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- ViewPager2 for flashcard swipe -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/recycler_words"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="24dp"
        android:paddingVertical="8dp" />

    <!-- Selected count and Start button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/text_selected_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp"
            android:text="Đã chọn: 0 từ"
            android:textColor="@color/white"
            android:textAppearance="@style/TextAppearance.VocabMaster.Caption" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_learn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Bắt đầu học"
            android:background="@drawable/button_login_neumorph"
            android:textColor="@color/bg_grey"
            app:backgroundTint="@null"
            android:textSize="16sp"
            app:cornerRadius="12dp" />
    </LinearLayout>

</LinearLayout>
