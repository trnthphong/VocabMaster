<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#4046d8">

    <!-- Header Toolbar -->
    <RelativeLayout
        android:id="@+id/toolbar_container"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/close"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Nâng cấp Premium"
            android:textAppearance="@style/TextAppearance.VocabMaster.H3"
            android:textColor="@color/white" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar_container">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_20"
            android:paddingBottom="@dimen/spacing_32">

            <!-- Promotion Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                android:text="Mở khóa tối đa tiềm năng"
                app:fontFamily="@font/adlam_display"
                android:textAppearance="@style/TextAppearance.VocabMaster.H2"
                android:textColor="@color/white"
                android:gravity="center" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Chọn gói dịch vụ phù hợp để bắt đầu hành trình mới"
                android:textAppearance="@style/TextAppearance.VocabMaster.BodyMedium"
                android:textColor="@color/white" />

            <!-- Student Plan Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_student"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_24"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/radius_large"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_16">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gói Student"
                        android:textAppearance="@style/TextAppearance.VocabMaster.H3"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Chỉ từ 15.000 ₫"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                        android:textColor="#4046d8"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="• Tính năng học tập cơ bản\n• Hạn chế một số trò chơi nâng cao"
                        android:textAppearance="@style/TextAppearance.VocabMaster.Caption"
                        android:textColor="@color/text_primary"
                        android:lineSpacingExtra="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_register_student"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Đăng ký gói Student"
                        android:textColor="@color/bg_grey"

                        app:cornerRadius="@dimen/radius_medium"
                        android:backgroundTint="@color/light_green" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- VIP Plan Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_vip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/radius_large"
                app:cardElevation="4dp"
                app:strokeColor="@color/white"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_16">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_toggle_pill"
                        android:backgroundTint="#4046d8"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="2dp"
                        android:text="Phổ biến nhất"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Gói VIP"
                        android:textAppearance="@style/TextAppearance.VocabMaster.H3"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Chỉ từ 25.000 ₫"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                        android:textColor="#4046d8"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="• Toàn bộ tính năng và khóa học\n• Không quảng cáo\n• Hỗ trợ ưu tiên"
                        android:textAppearance="@style/TextAppearance.VocabMaster.Caption"
                        android:textColor="@color/text_primary"
                        android:lineSpacingExtra="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_register_vip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Đăng ký gói VIP"
                        android:textColor="@color/bg_grey"
                        app:cornerRadius="@dimen/radius_medium"
                        android:backgroundTint="@color/light_green" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- VVIP Plan Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_vvip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/radius_large"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_16">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gói VVIP"
                        android:textAppearance="@style/TextAppearance.VocabMaster.H3"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Chỉ từ 35.000 ₫"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                        android:textColor="#4046d8"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="• Không giới hạn Heart (Trái tim)\n• Toàn bộ tính năng Try Again\n• Nội dung độc quyền"
                        android:textAppearance="@style/TextAppearance.VocabMaster.Caption"
                        android:textColor="@color/text_primary"
                        android:lineSpacingExtra="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_register_vvip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Đăng ký gói VVIP"
                        android:textColor="@color/bg_grey"
                        app:cornerRadius="@dimen/radius_medium"
                        android:backgroundTint="@color/light_green" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Security Trust -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/star"
                    app:tint="@color/white" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Thanh toán an toàn qua MoMo"
                    android:textAppearance="@style/TextAppearance.VocabMaster.Caption"
                    android:textColor="@color/white" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
