<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_light">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/spacing_64">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_24">

            <nl.dionsegijn.konfetti.xml.KonfettiView
                android:id="@+id/konfettiView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                tools:layout_editor_absoluteX="0dp"
                tools:layout_editor_absoluteY="0dp" />

            <!-- Hero Section: Greeting Header -->
            <RelativeLayout
                android:id="@+id/header_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_8"
                android:layout_marginBottom="@dimen/spacing_24">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/text_greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good Morning,"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                        android:textColor="@color/gray_text" />

                    <TextView
                        android:id="@+id/text_user_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Student"
                        android:textAppearance="@style/TextAppearance.VocabMaster.H2"
                        android:textColor="@color/surface_dark" />
                </LinearLayout>

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_profile"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/bear"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.VocabMaster.Medium"
                    app:strokeColor="@color/brand_primary_light"
                    app:strokeWidth="2dp" />

            </RelativeLayout>

            <!-- Stats Grid (Combined Course Progress & Global Stats) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/stats_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_main"
                android:padding="@dimen/spacing_20"
                android:elevation="@dimen/elevation_medium"
                android:clipToPadding="false">

                <!-- Top Row: Global Stats -->
                <LinearLayout
                    android:id="@+id/layout_global_stats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="16dp"
                    app:layout_constraintTop_toTopOf="parent">

                    <LinearLayout
                        android:id="@+id/layout_streak"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/streak" />
                        <TextView
                            android:id="@+id/tv_streak_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="12"
                            android:textColor="#FF9800"
                            android:textStyle="bold"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layout_xp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/exp" />
                        <TextView
                            android:id="@+id/tv_xp_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="1250"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layout_heart"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_vertical|end">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/heart" />
                        <TextView
                            android:id="@+id/text_hearts"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="5"
                            android:textColor="@color/error"
                            android:textStyle="bold"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:id="@+id/divider_stats"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/glass_white_20"
                    app:layout_constraintTop_toBottomOf="@id/layout_global_stats" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_current_course_flag"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginTop="16dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/eng"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/divider_stats" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="@id/img_current_course_flag"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/img_current_course_flag"
                    app:layout_constraintTop_toTopOf="@id/img_current_course_flag">

                    <TextView
                        android:id="@+id/text_current_course_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tiếng Anh"
                        android:textColor="@color/white"
                        android:textAppearance="@style/TextAppearance.VocabMaster.Caption"
                        android:alpha="0.8" />

                    <TextView
                        android:id="@+id/text_current_unit_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chương 1: Khởi đầu"
                        android:textColor="@color/white"
                        android:textAppearance="@style/TextAppearance.VocabMaster.H3"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/progress_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical"
                    app:layout_constraintTop_toBottomOf="@id/img_current_course_flag">

                    <TextView
                        android:id="@+id/text_course_progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tiến độ chương: 0%"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progress_course"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_8"
                        app:indicatorColor="@color/brand_secondary"
                        app:trackColor="@color/glass_white_40"
                        app:trackCornerRadius="@dimen/radius_full"
                        app:trackThickness="10dp"
                        android:progress="0" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Heart Regeneration Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_heart_regen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                android:visibility="gone"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/radius_large"

                app:strokeWidth="0dp"
                tools:visibility="visible">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_16">

                    <ImageView
                        android:id="@+id/icon_heart_regen"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/heart"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/label_regen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_16"
                        android:text="Hồi phục tim tiếp theo"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyMedium"
                        android:textColor="@color/gray_text"
                        app:layout_constraintStart_toEndOf="@id/icon_heart_regen"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/text_heart_timer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_16"
                        android:text="04:59"
                        android:textAppearance="@style/TextAppearance.VocabMaster.H3"
                        android:textColor="@color/error"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@id/icon_heart_regen"
                        app:layout_constraintTop_toBottomOf="@id/label_regen" />

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/regen_progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:indicatorColor="@color/error"
                        app:indicatorSize="40dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:trackColor="@color/gray_lighter"
                        app:trackThickness="4dp"
                        android:progress="60" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- New Section: Start a new journey -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_32"
                android:layout_marginBottom="@dimen/spacing_16"
                android:text="START A NEW JOURNEY"
                android:textAppearance="@style/TextAppearance.VocabMaster.H3"
                android:textColor="@color/gray_text" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="@dimen/spacing_8">

                    <!-- Theme Card 1: Business -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="140dp"
                        android:layout_height="180dp"
                        android:layout_marginEnd="@dimen/spacing_16"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="@dimen/radius_large"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_16"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/buss"
                                 />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_12"
                                android:text="Business"
                                android:textAppearance="@style/TextAppearance.VocabMaster.H3"
                                android:textAlignment="center" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pro terms"
                                android:textAppearance="@style/TextAppearance.VocabMaster.Caption"
                                android:textAlignment="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Theme Card 2: Travel -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="140dp"
                        android:layout_height="180dp"
                        android:layout_marginEnd="@dimen/spacing_16"
                        app:cardCornerRadius="@dimen/radius_large"
                        app:cardBackgroundColor="@color/white"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_16"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/trav"
                                 />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_12"
                                android:text="Travel"
                                android:textAppearance="@style/TextAppearance.VocabMaster.H3"
                                android:textAlignment="center" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="World explorer"
                                android:textAppearance="@style/TextAppearance.VocabMaster.Caption"
                                android:textAlignment="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Theme Card 3: Academic -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="140dp"
                        android:layout_height="180dp"
                        app:cardCornerRadius="@dimen/radius_large"
                        app:cardBackgroundColor="@color/white"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_16"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/acad"
                                 />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_12"
                                android:text="Academic"
                                android:textAppearance="@style/TextAppearance.VocabMaster.H3"
                                android:textAlignment="center" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Exam prep"
                                android:textAppearance="@style/TextAppearance.VocabMaster.Caption"
                                android:textAlignment="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Main Actions (Daily Tasks) -->
            <TextView
                android:id="@+id/label_actions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_32"
                android:layout_marginBottom="@dimen/spacing_16"
                android:text="DAILY TASKS"
                android:textAppearance="@style/TextAppearance.VocabMaster.H3"
                android:textColor="@color/gray_text" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_start_flashcards"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="@dimen/spacing_16"
                app:cardCornerRadius="@dimen/radius_large"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="@dimen/spacing_16">

                    <ImageView
                        android:id="@+id/icon_cards"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_glass_card"
                        android:padding="8dp"
                        android:src="@drawable/planning"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                         />

                    <TextView
                        android:id="@+id/text_cards_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_16"
                        android:text="Spaced Repetition"
                        android:textAppearance="@style/TextAppearance.VocabMaster.H3"
                        app:layout_constraintBottom_toTopOf="@id/sub_cards"
                        app:layout_constraintStart_toEndOf="@id/icon_cards"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_chainStyle="packed" />

                    <TextView
                        android:id="@+id/sub_cards"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_16"
                        android:text="Master 15 new words today"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@id/icon_cards"
                        app:layout_constraintTop_toBottomOf="@id/text_cards_title" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_media_play"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/gray_light" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_play_mini_game"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="@dimen/spacing_16"
                app:cardCornerRadius="@dimen/radius_large"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="@dimen/spacing_16">

                    <ImageView
                        android:id="@+id/icon_games"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_glass_card"
                        android:padding="8dp"
                        android:src="@drawable/game"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                         />

                    <TextView
                        android:id="@+id/text_games_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_16"
                        android:text="Quick Games"
                        android:textAppearance="@style/TextAppearance.VocabMaster.H3"
                        app:layout_constraintBottom_toTopOf="@id/sub_games"
                        app:layout_constraintStart_toEndOf="@id/icon_games"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_chainStyle="packed" />

                    <TextView
                        android:id="@+id/sub_games"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_16"
                        android:text="Fun way to memorize"
                        android:textAppearance="@style/TextAppearance.VocabMaster.BodyLarge"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@id/icon_games"
                        app:layout_constraintTop_toBottomOf="@id/text_cards_title" />

                    <TextView
                        android:id="@+id/text_premium_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_glass_card"
                        android:backgroundTint="@color/warning"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:text="PRO"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/spacing_24"
        android:text="New Course"
        app:icon="@android:drawable/ic_input_add"
        app:backgroundTint="@color/brand_primary"
        android:textColor="@color/white"
        app:iconTint="@color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
