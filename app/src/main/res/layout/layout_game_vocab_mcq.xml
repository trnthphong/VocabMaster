<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/text_question_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="NGHE PHÁT ÂM"
        android:textColor="@color/brand_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="2dp"
        app:strokeColor="@color/card_border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <ImageButton
                android:id="@+id/btn_play_audio"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_circle_accent"
                android:src="@drawable/volume"
                android:visibility="gone"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/text_question_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Definition goes here"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_option_1"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="60dp"
        android:layout_marginBottom="12dp"
        android:text="Option 1"
        android:paddingVertical="12dp"
        android:textAllCaps="false"
        app:cornerRadius="16dp"
        app:strokeColor="@color/card_border" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_option_2"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="60dp"
        android:layout_marginBottom="12dp"
        android:text="Option 2"
        android:paddingVertical="12dp"
        android:textAllCaps="false"
        app:cornerRadius="16dp"
        app:strokeColor="@color/card_border" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_option_3"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="60dp"
        android:layout_marginBottom="12dp"
        android:text="Option 3"
        android:paddingVertical="12dp"
        android:textAllCaps="false"
        app:cornerRadius="16dp"
        app:strokeColor="@color/card_border" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_option_4"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="60dp"
        android:text="Option 4"
        android:paddingVertical="12dp"
        android:textAllCaps="false"
        app:cornerRadius="16dp"
        app:strokeColor="@color/card_border" />

</LinearLayout>
